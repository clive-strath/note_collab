'use client'

import { useState } from 'react'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { useAuth } from '@/contexts/AuthContext'
import { Mail, Lock, User, Send, CheckCircle } from 'lucide-react'

type Mode = 'signin' | 'signup'

export function LoginForm() {
  const [mode, setMode] = useState<Mode>('signin')
  const [email, setEmail] = useState('')
  const [password, setPassword] = useState('')
  const [name, setName] = useState('')
  const [isLoading, setIsLoading] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [message, setMessage] = useState<string | null>(null)
  const [showPlane, setShowPlane] = useState(false)
  const { signIn, signUp, signInWithGoogle } = useAuth()

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    setIsLoading(true)
    setError(null)
    setMessage(null)

    if (mode === 'signin') {
      const { error } = await signIn(email, password)
      if (error) {
        setError(error)
        setIsLoading(false)
      } else {
        setShowPlane(true)
        setTimeout(() => setIsLoading(false), 800)
      }
    } else {
      const { error } = await signUp(email, password, name)
      if (error) {
        setError(error)
        setIsLoading(false)
      } else {
        setMessage('Check your email to confirm your account!')
        setIsLoading(false)
      }
    }
  }

  const handleGoogleLogin = async () => {
    setIsLoading(true)
    setError(null)
    const { error } = await signInWithGoogle()
    if (error) {
      setError(error)
      setIsLoading(false)
    }
  }

  const switchMode = (newMode: Mode) => {
    setMode(newMode)
    setError(null)
    setMessage(null)
    setShowPlane(false)
  }

  return (
    <div className="relative w-full max-w-md mx-auto">
      {/* Floating paper airplane animation on success */}
      {showPlane && (
        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 pointer-events-none animate-plane-fly">
          <Send className="h-12 w-12 text-amber-500 drop-shadow-lg" style={{ transform: 'rotate(-45deg)' }} />
        </div>
      )}

      {/* Main paper card */}
      <div className="relative paper-card-3d p-8">
        {/* Paper clip at top */}
        <div className="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
          <div className="w-8 h-8" style={{
            background: 'linear-gradient(135deg, #D4A574 0%, #C49564 50%, #B48554 100%)',
            borderRadius: '50% 50% 0 0',
            transform: 'rotate(45deg)',
            boxShadow: '0 2px 4px rgba(0,0,0,0.15), inset 0 -1px 2px rgba(255,255,255,0.3)',
          }} />
        </div>

        {/* Header */}
        <div className="text-center mb-8 relative z-10">
          {/* 3D Paper logo */}
          <div className="w-16 h-16 mx-auto mb-4 perspective-1000" style={{ perspective: '1000px' }}>
            <div className="w-full h-full preserve-3d animate-float-slow" style={{ transformStyle: 'preserve-3d' }}>
              <div className="absolute inset-0 rounded-xl shadow-paper" style={{
                transform: 'translateZ(3px)',
                background: 'linear-gradient(180deg, #FFFEF7 0%, #F9F5E1 100%)',
                border: '1px solid rgba(132, 121, 108, 0.15)',
              }}>
                <div className="absolute inset-1" style={{
                  backgroundImage: 'repeating-linear-gradient(transparent 0, transparent 10px, rgba(173, 216, 230, 0.3) 10px, rgba(173, 216, 230, 0.3) 11px)',
                  backgroundSize: '100% 11px',
                  borderRadius: '8px',
                }} />
                <div className="absolute left-4 top-0 bottom-0 w-px" style={{
                  background: 'rgba(231, 76, 60, 0.5)',
                }} />
                <div className="absolute top-0 right-0 w-4 h-4" style={{
                  background: 'linear-gradient(135deg, transparent 50%, rgba(0,0,0,0.05) 50%)',
                  borderRadius: '0 8px 0 0',
                }} />
              </div>
              <div className="absolute inset-0 rounded-xl" style={{
                transform: 'translateZ(-3px) rotateY(180deg)',
                background: 'linear-gradient(180deg, #F2ECC3 0%, #E8DEA0 100%)',
                border: '1px solid rgba(132, 121, 108, 0.1)',
              }} />
            </div>
          </div>
          <h1 className="text-2xl font-semibold text-ink-900 font-caveat tracking-wide">Paperverse</h1>
          <p className="text-sm text-ink-500 mt-1">
            {mode === 'signin' ? 'Sign in to your paper world' : 'Create your paper space'}
          </p>
        </div>

        {/* Tab switcher - styled as paper tabs */}
        <div className="flex rounded-lg bg-ink-100/50 p-1 mb-6 relative z-10">
          <button
            onClick={() => switchMode('signin')}
            className={`flex-1 py-2 text-sm font-medium rounded-md transition-all ${
              mode === 'signin' 
                ? 'bg-paper-100 shadow-paper text-ink-900' 
                : 'text-ink-500 hover:text-ink-700'
            }`}
          >
            Sign In
          </button>
          <button
            onClick={() => switchMode('signup')}
            className={`flex-1 py-2 text-sm font-medium rounded-md transition-all ${
              mode === 'signup' 
                ? 'bg-paper-100 shadow-paper text-ink-900' 
                : 'text-ink-500 hover:text-ink-700'
            }`}
          >
            Sign Up
          </button>
        </div>

        {error && (
          <div className="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600 sticky-note relative z-10">
            {error}
          </div>
        )}
        {message && (
          <div className="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-600 sticky-note relative z-10">
            <div className="flex items-center space-x-1.5">
              <CheckCircle className="h-4 w-4" />
              {message}
            </div>
          </div>
        )}

        <form onSubmit={handleSubmit} className="space-y-4 relative z-10">
          {mode === 'signup' && (
            <div className="sticky-note-input">
              <label htmlFor="name" className="block text-sm font-medium text-ink-700 mb-1.5">
                <User className="inline h-4 w-4 mr-1.5 -ml-0.5 text-ink-400" />
                Full Name
              </label>
              <div className="relative">
                <Input
                  id="name"
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  placeholder="John Doe"
                  required
                  className="input-paper pl-10"
                />
                <User className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink-300" />
              </div>
            </div>
          )}

          <div className="sticky-note-input">
            <label htmlFor="email" className="block text-sm font-medium text-ink-700 mb-1.5">
              <Mail className="inline h-4 w-4 mr-1.5 -ml-0.5 text-ink-400" />
              Email
            </label>
            <div className="relative">
              <Input
                id="email"
                type="email"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                placeholder="you@example.com"
                required
                className="input-paper pl-10"
              />
              <Mail className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink-300" />
            </div>
          </div>

          <div className="sticky-note-input">
            <label htmlFor="password" className="block text-sm font-medium text-ink-700 mb-1.5">
              <Lock className="inline h-4 w-4 mr-1.5 -ml-0.5 text-ink-400" />
              Password
            </label>
            <div className="relative">
              <Input
                id="password"
                type="password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                placeholder="••••••••"
                required
                minLength={6}
                className="input-paper pl-10"
              />
              <Lock className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-ink-300" />
            </div>
          </div>

          <Button 
            type="submit" 
            className="w-full btn-paper" 
            disabled={isLoading}
          >
            {isLoading && mode === 'signin' ? (
              <span className="flex items-center justify-center space-x-2">
                <svg className="animate-spin h-5 w-5" viewBox="0 0 24 24">
                  <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4" fill="none" />
                  <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
                </svg>
                <span>Opening your notebook...</span>
              </span>
            ) : isLoading ? (
              'Creating your space...'
            ) : mode === 'signin' ? (
              <span className="flex items-center justify-center space-x-2">
                Sign In
                <Send className="h-4 w-4" style={{ transform: 'rotate(-45deg)' }} />
              </span>
            ) : (
              'Create Account'
            )}
          </Button>
        </form>

        <div className="mt-6 relative z-10">
          <div className="relative">
            <div className="absolute inset-0 flex items-center">
              <div className="w-full border-t border-ink-200" />
            </div>
            <div className="relative flex justify-center text-sm">
              <span className="px-3 bg-paper-100 text-ink-400">Or continue with</span>
            </div>
          </div>

          <Button
            variant="outline"
            className="w-full mt-4 btn-outline-paper"
            onClick={handleGoogleLogin}
            disabled={isLoading}
            type="button"
          >
            <svg className="w-4 h-4 mr-2" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            Continue with Google
          </Button>
        </div>
      </div>

      {/* Decorative sticky notes floating around */}
      <div className="pointer-events-none absolute inset-0 -z-10" style={{ overflow: 'visible' }}>
        <div className="absolute -top-4 -right-6 w-20 h-20 opacity-60 animate-drift" style={{ 
          transform: 'rotate(-12deg)',
          background: 'linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%)',
          boxShadow: '2px 2px 8px rgba(0,0,0,0.1)',
          borderRadius: '4px',
        }}>
          <div className="p-2 text-xs text-amber-700 font-caveat leading-relaxed">Welcome to<br/>Paperverse</div>
          <div className="absolute top-1 right-1 w-2 h-2 rounded-full" style={{ background: '#D4A574' }} />
        </div>
        <div className="absolute -bottom-6 -left-4 w-24 h-16 opacity-50 animate-drift" style={{ 
          transform: 'rotate(8deg)',
          animationDelay: '1s',
          background: 'linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%)',
          boxShadow: '2px 2px 8px rgba(0,0,0,0.1)',
          borderRadius: '4px',
        }}>
          <div className="p-1.5 text-xs text-blue-700 font-caveat leading-relaxed">Your notes,<br/>alive</div>
          <div className="absolute top-1 right-1 w-2 h-2 rounded-full" style={{ background: '#60A5FA' }} />
        </div>
        <div className="absolute top-1/2 -right-10 w-16 h-16 opacity-40 animate-float" style={{ 
          transform: 'rotate(-5deg)',
          animationDelay: '0.5s',
          background: 'linear-gradient(135deg, #FCE7F3 0%, #FBCFE8 100%)',
          boxShadow: '2px 2px 8px rgba(0,0,0,0.1)',
          borderRadius: '4px',
        }}>
          <div className="p-1.5 text-xs text-pink-700 font-caveat leading-relaxed text-center">✎</div>
          <div className="absolute top-1 right-1 w-2 h-2 rounded-full" style={{ background: '#F472B6' }} />
        </div>
      </div>
    </div>
  )
}